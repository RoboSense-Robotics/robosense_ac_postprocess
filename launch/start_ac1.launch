<launch>
	<arg name="rviz" default="true" />

	<rosparam command="load" file="$(find robosense_ac_postprocess)/config/usr_config_ac1.yaml" />

	<node pkg="robosense_ac_postprocess" type="postprocess_node" name="postprocess_node" output="screen" args="--config $(find robosense_ac_postprocess)/config/usr_config_ac1.yaml" cwd="node">
		<rosparam file="$(find robosense_ac_postprocess)/config/usr_config_ac1.yaml" />
	</node>

	<group if="$(arg rviz)">
		<node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find robosense_ac_postprocess)/rviz_config/rviz_config.rviz" />
	</group>
</launch>
